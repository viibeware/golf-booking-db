# Golf Booking Database - Environment Configuration
# Copy this file to .env and update the values before deploying.
#
#   cp .env.example .env
#
# Then generate a secret key:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# and paste the output as the SECRET_KEY value below.

SECRET_KEY=change-me-generate-a-real-key
DATABASE=/data/golf_booking_db.db
APP_PORT=5055
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASS=admin
